# --- Rust & Cargo Core Footprints ---
/target/
Cargo.lock
**/*.rs.bk

# --- Local Environment & Secret Stores ---
.env
.env.*
!.env.example
env
~/.config/mcp-proxy/env

# --- Operating System & Desktop Leftovers ---
.DS_Store
Thumbs.db
*.log
*.bak
*.bak.*

# --- IDE Settings & Workspace Metadata ---
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp

# --- Platform Testing Sidecars ---
/mcp-proxy/examples/demo_plugin/target/
*.tar.gz
bin/
